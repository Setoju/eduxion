<div class="container">
  <section class="auth-page">
    <div class="auth-form auth-card">
      <header class="auth-card__header">
        <h1>Sign In</h1>
        <p>Welcome back. Continue where you left off.</p>
      </header>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form__fields", novalidate: true }) do |f| %>
      <div class="field mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                       class: "form-control", 
                       required: true %>
      </div>

      <div class="field mb-3">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", 
                          class: "form-control", 
                          required: true %>
      </div>

    <% if devise_mapping.rememberable? %>
      <div class="field mb-3">
        <div class="form-check">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, class: "form-check-label" %>
        </div>
      </div>
    <% end %>

    <div class="actions">
      <%= f.submit "Log in", class: "btn btn-primary" %>
    </div>
      <% end %>

      <div class="links mt-3 auth-links">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </section>
</div>
