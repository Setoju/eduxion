<div class="container">
  <section class="center">
    <header class="page-summary">
      <div>
        <h1 class="page-title">Courses</h1>
        <p class="page-subtitle">Browse, filter, and continue learning from one compact dashboard.</p>
      </div>
      <% if policy(Course).create? %>
        <%= link_to "New Course", new_course_path, class: "app-btn app-btn--primary" %>
      <% end %>
    </header>

    <% if current_user %>
      <section class="search-panel" aria-labelledby="courses-search-title">
        <h2 id="courses-search-title" class="search-panel__title">Search and Filter</h2>
        <%= search_form_for @q, url: courses_path, method: :get do |f| %>
          <div class="search-bar-row">
            <label class="search-inline-field">
              <span class="search-field__label"><i class="bi bi-type" aria-hidden="true"></i> Title</span>
              <%= f.search_field :title_cont, placeholder: "Search title" %>
            </label>

            <label class="search-inline-field">
              <span class="search-field__label"><i class="bi bi-text-paragraph" aria-hidden="true"></i> Description</span>
              <%= text_field_tag "q[description_cont]", params.dig(:q, :description_cont), placeholder: "Search description" %>
            </label>
          </div>

          <% filter_active = params.dig(:q, :lessonable) == "1" ||
                            params.dig(:q, :enrolled) == "1" ||
                            params.dig(:q, :created) == "1" ||
                            params.dig(:q, :recent) == "1" %>
          <details class="filter-drawer" <%= "open" if filter_active %>>
            <summary><i class="bi bi-funnel" aria-hidden="true"></i> Filters</summary>
            <div class="filter-chip-group">
              <label class="search-toggle search-toggle--compact">
                <%= check_box_tag "q[lessonable]", "1", params.dig(:q, :lessonable) == "1" %>
                <span><i class="bi bi-list-check" aria-hidden="true"></i> Has lessons</span>
              </label>

              <label class="search-toggle search-toggle--compact">
                <%= check_box_tag "q[enrolled]", "1", params.dig(:q, :enrolled) == "1" %>
                <span><i class="bi bi-mortarboard" aria-hidden="true"></i> Enrolled courses</span>
              </label>

              <% if current_user.teacher? %>
                <label class="search-toggle search-toggle--compact">
                  <%= check_box_tag "q[created]", "1", params.dig(:q, :created) == "1" %>
                  <span><i class="bi bi-easel2" aria-hidden="true"></i> My courses</span>
                </label>
              <% end %>

              <label class="search-toggle search-toggle--compact">
                <%= check_box_tag "q[recent]", "1", params.dig(:q, :recent) == "1" %>
                <span><i class="bi bi-clock-history" aria-hidden="true"></i> Recent courses</span>
              </label>
            </div>
          </details>

          <div class="search-actions" role="toolbar" aria-label="Search actions">
            <%= f.submit "Search", class: "app-btn app-btn--primary" %>
            <%= link_to "Clear", courses_path, class: "app-btn app-btn--ghost" %>
            <%= sort_link(@q, :title, "Sort by title") %>
          </div>
        <% end %>
      </section>
    <% end %>

    <div class="courses-list">
      <% if @courses.any? %>
        <% @courses.each do |course| %>
          <article class="course">
            <div class="course-header">
              <h3 class="course-title"><%= course.title %></h3>
              <div class="course-meta">
                <p class="instructor">Instructor: <%= course.instructor.first_name %></p>
                <% if course.is_archived %>
                  <span class="badge badge-public">Archived</span>
                <% end %>
                <span class="badge <%= course.public ? "badge-public" : "badge-private" %>">
                  <%= course.public ? "Public" : "Private" %>
                </span>
                <% if current_user&.student? && current_user.enrolled_in?(course) %>
                  <span class="badge badge-enrolled">Enrolled</span>
                <% end %>
              </div>
            </div>

            <p class="course-description"><%= course.description %></p>

            <div class="course-actions">
              <%= link_to "View", course_path(course), class: "course-link course-link-primary" %>
              <% if current_user&.student? && !current_user.enrolled_in?(course) && course.public %>
                <%= button_to "Enroll in Course",
                              course_enrollments_path(course),
                              method: :post,
                              class: "course-link course-link-primary" %>
              <% end %>
              <% if current_user&.student? && current_user.enrolled_in?(course) %>
                <%= button_to "Leave",
                              course_enrollment_path(course, current_user.enrollments.find_by(course: course)),
                              method: :delete,
                              data: { confirm: "Are you sure you want to leave this course?" },
                              class: "course-link course-link-danger" %>
              <% end %>
              <% if policy(course).update? %>
                <%= link_to "Edit", edit_course_path(course), class: "course-link course-link-warning" %>
                <%= button_to "Delete",
                              course_path(course),
                              method: :delete,
                              data: { confirm: "Are you sure?" },
                              class: "course-link course-link-danger" %>
              <% end %>
            </div>
          </article>
        <% end %>
      <% else %>
        <div class="course-empty">No courses matched your filters.</div>
      <% end %>
    </div>

    <%= paginate @courses %>
  </section>
</div>
