<div class="container">
  <section class="auth-page">
    <div class="auth-form auth-card auth-card--wide">
      <header class="auth-card__header">
        <h1>Create Account</h1>
        <p>Join as a student or teacher and start learning.</p>
      </header>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form__fields", novalidate: true }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <fieldset class="auth-fieldset">
          <legend>Account</legend>

          <div class="field mb-3">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                           class: "form-control", 
                           required: true %>
          </div>

          <div class="field mb-3">
            <%= f.label :password, class: "form-label" %>
            <% if @minimum_password_length %>
              <div class="form-text">
                (<%= @minimum_password_length %> characters minimum)
              </div>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", 
                              class: "form-control", 
                              required: true %>
          </div>

          <div class="field mb-3">
            <%= f.label :password_confirmation, class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", 
                              class: "form-control", 
                              required: true %>
          </div>
        </fieldset>

        <fieldset class="auth-fieldset">
          <legend>Profile</legend>

          <div class="field mb-3">
            <%= f.label :first_name, class: "form-label" %>
            <%= f.text_field :first_name, class: "form-control", required: true %>
          </div>

          <div class="field mb-3">
            <%= f.label :last_name, class: "form-label" %>
            <%= f.text_field :last_name, class: "form-control", required: true %>
          </div>

          <div class="field mb-3">
            <%= f.label :role, class: "form-label" %>
            <%= f.select :role, 
              options_for_select([["Student", "student"], ["Teacher", "teacher"]]), 
              { prompt: "Select Role" }, 
              { class: "form-select", required: true } %>
          </div>

          <div class="field mb-3">
            <%= f.label :avatar, class: "form-label" %>
            <%= f.file_field :avatar, class: "form-control" %>
          </div>
        </fieldset>

        <div class="actions">
          <%= f.submit "Sign up", class: "btn btn-primary" %>
        </div>
      <% end %>

      <div class="links mt-3 auth-links">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </section>
</div>


